FROM golang:1.22-alpine AS builder
WORKDIR /workspace
COPY . .
ARG ENGINE=trip
RUN go work sync && cd backend/engines/${ENGINE} && CGO_ENABLED=0 GOOS=linux go build -o /engine ./cmd/${ENGINE}

FROM alpine:3.19
RUN apk --no-cache add ca-certificates
COPY --from=builder /engine /engine
EXPOSE 8080
ENTRYPOINT ["/engine"]
