# CYTAXI - Environment Configuration
# Copy this file to .env and fill values

# Application
APP_ENV=development
APP_NAME=cytaxi
APP_PORT=8080
APP_DEBUG=true

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=cytaxi
DATABASE_PASSWORD=changeme
DATABASE_NAME=cytaxi_dev
DATABASE_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Observability
OTEL_SERVICE_NAME=cytaxi
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Auth
JWT_SECRET=changeme
JWT_EXPIRATION=24h

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
